---
layout: base.njk
title: "Industries We Serve | Fiber Conversion Inc. - Recycled Fibers for Every Application"
description: "Fiber Conversion supplies recycled fibers to automotive, furniture, insulation, nonwovens, paper, and industrial manufacturing industries. Cost-effective sustainable alternatives."
keywords: "recycled fibers automotive, furniture padding fibers, insulation fibers, nonwoven fiber supply, industrial recycled fibers, textile recycling industries"
canonical: "https://fiberconversion.net/industries.html"
ogTitle: "Industries We Serve | Fiber Conversion Inc."
ogDescription: "Supplying quality recycled fibers to automotive, furniture, insulation, and industrial manufacturing sectors."
activePage: industries
permalink: industries.html
---
{% from "media.njk" import media, icon %}

{# ============================================
   PAGE HERO
   ============================================ #}
<section class="page-hero{% if industries.hero.heroImage %} page-hero--has-image{% endif %}{% if industries.hero.heroVideoUrl or industries.hero.heroVideoFile %} page-hero--has-video{% endif %}"
  {% if industries.hero.heroImage %}style="--hero-bg-image: url('{{ industries.hero.heroImage }}')"{% endif %}>
  <div class="container">
    <div class="page-hero__content">
      <span class="label">{{ industries.hero.label }}</span>
      <h1>{{ industries.hero.title }}</h1>
      <p>{{ industries.hero.description | safe }}</p>
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Industries</span>
      </nav>
    </div>
  </div>
  {% if industries.hero.heroVideoUrl %}
    <div class="hero__video" data-video-url="{{ industries.hero.heroVideoUrl | videoEmbed }}">
      <noscript><iframe src="{{ industries.hero.heroVideoUrl | videoEmbed }}" frameborder="0" allowfullscreen></iframe></noscript>
    </div>
  {% elif industries.hero.heroVideoFile %}
    <div class="hero__video">
      <video src="{{ industries.hero.heroVideoFile }}" autoplay muted loop playsinline></video>
    </div>
  {% endif %}
</section>

{# ============================================
   SECTION HEADER
   ============================================ #}
<section class="section">
  <div class="container">
    <div class="section-header fade-in">
      <span class="label">{{ industries.sectionHeader.label }}</span>
      <h2>{{ industries.sectionHeader.title }}</h2>
      <p>{{ industries.sectionHeader.description }}</p>
    </div>
  </div>
</section>

{# ============================================
   INDUSTRY DETAIL SECTIONS
   ============================================ #}
{% set industrySvgs = [
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="15" y="45" width="90" height="35" rx="8"/><path d="M30 45V35a5 5 0 015-5h50a5 5 0 015 5v10"/><circle cx="32" cy="85" r="10"/><circle cx="88" cy="85" r="10"/><path d="M42 80h36"/></svg>',
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M60 15L15 50v55h90V50L60 15z"/><rect x="45" y="70" width="30" height="35"/><rect x="25" y="55" width="15" height="15"/><rect x="80" y="55" width="15" height="15"/></svg>',
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="20" y="50" width="80" height="30" rx="5"/><rect x="15" y="40" width="15" height="40" rx="5"/><rect x="90" y="40" width="15" height="40" rx="5"/><rect x="25" y="80" width="5" height="15"/><rect x="90" y="80" width="5" height="15"/></svg>',
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 30h80M20 45h80M20 60h80M20 75h80M20 90h80"/><path d="M30 25v70M50 25v70M70 25v70M90 25v70"/></svg>',
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="25" y="20" width="70" height="85" rx="3"/><path d="M40 40h40M40 50h40M40 60h40M40 70h25"/><path d="M25 20h50l20 20" /><path d="M75 20v20h20"/></svg>',
  '<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="15" y="40" width="35" height="55" rx="3"/><rect x="55" y="25" width="25" height="70" rx="3"/><rect x="85" y="50" width="20" height="45" rx="3"/><path d="M25 40V25l10-10 10 10v15"/><circle cx="67" cy="20" r="5"/></svg>'
] %}

{% set bgClasses = ['', ' section--gray', '', ' section--gray', '', ' section--gray'] %}

{% for item in industries.items %}
<section class="section{{ bgClasses[loop.index0] }}" id="{{ item.id }}">
  <div class="container">
    <div class="service-detail fade-in">
      <div class="service-detail__content">
        <span class="label">{{ item.label }}</span>
        <h3>{{ item.title | safe }}</h3>
        <p>{{ item.description }}</p>
        <ul>
          {% for app in item.applications %}
          <li>{{ app }}</li>
          {% endfor %}
        </ul>
        <a href="contact.html" class="btn btn--outline">{{ item.ctaText }}</a>
      </div>
          <div class="service-detail__visual{% if item.image or item.videoUrl or item.videoFile %} service-detail__visual--has-media{% endif %}">
            {{ media(item.videoUrl, item.videoFile, item.image, item.imageAlt, industrySvgs[loop.index0]) }}
          </div>
    </div>
  </div>
</section>
{% endfor %}

{# ============================================
   CTA BANNER
   ============================================ #}
<section class="section">
  <div class="container">
    <div class="cta-banner fade-in">
      <h2>{{ industries.ctaBanner.title }}</h2>
      <p>{{ industries.ctaBanner.description }}</p>
      <a href="contact.html" class="btn btn--secondary btn--large">{{ industries.ctaBanner.buttonText }}</a>
    </div>
  </div>
</section>
