---
layout: base.njk
title: "Fiber Conversion Inc. | Textile Recycling & Fiber Processing Since 1909"
description: "Fiber Conversion Inc. has been recycling and processing textile byproducts for industrial use since 1909. Sustainable fiber solutions for automotive, furniture, insulation and more."
keywords: "textile recycling, fiber processing, recycled fibers, textile waste management, industrial fibers, sustainable materials, fiber conversion"
canonical: "https://fiberconversion.net/"
ogTitle: "Fiber Conversion Inc. | Textile Recycling & Fiber Processing"
ogDescription: "Over a century of expertise in recycling and processing textile byproducts into high-quality industrial fibers."
ogUrl: "https://fiberconversion.net/"
activePage: home
permalink: index.html
---

{# ========================================
   HERO SECTION
   ======================================== #}
<section class="hero">
  <div class="container">
    <div class="hero__content fade-in">
      <span class="hero__label">{{ homepage.hero.label }}</span>
      <h1>{{ homepage.hero.title }} <span class="highlight">{{ homepage.hero.titleHighlight }}</span></h1>
      <p class="hero__description">{{ homepage.hero.description }}</p>
      <div class="hero__buttons">
        <a href="services.html" class="btn btn--primary btn--large">{{ homepage.hero.primaryButtonText }}</a>
        <a href="contact.html" class="btn btn--outline-white btn--large">{{ homepage.hero.secondaryButtonText }}</a>
      </div>
      <div class="hero__stats">
        {% for stat in homepage.hero.stats %}
          <div class="hero__stat">
            {% if stat.dataCount %}
              <span class="hero__stat-number" data-count="{{ stat.dataCount }}" data-suffix="{{ stat.dataSuffix }}">{{ stat.number }}</span>
            {% else %}
              <span class="hero__stat-number">{{ stat.number }}</span>
            {% endif %}
            <span class="hero__stat-label">{{ stat.label }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
  <div class="hero__decoration" aria-hidden="true">
    <svg viewBox="0 0 600 600" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="300" cy="300" r="200" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
      <circle cx="300" cy="300" r="250" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
      <circle cx="300" cy="300" r="300" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
    </svg>
  </div>
</section>

{# ========================================
   SERVICES OVERVIEW
   ======================================== #}
<section class="section" id="services">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-header__label">{{ homepage.servicesSection.label }}</span>
      <h2>{{ homepage.servicesSection.title }}</h2>
      <p>{{ homepage.servicesSection.description }}</p>
    </div>

    {% set serviceIcons = [
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>'
    ] %}

    <div class="card-grid card-grid--3 stagger-children">
      {% for card in homepage.servicesSection.cards %}
        <div class="card fade-in">
          <div class="card__icon">
            {{ serviceIcons[loop.index0] | safe }}
          </div>
          <h3>{{ card.title }}</h3>
          <p>{{ card.description }}</p>
          <a href="services.html" class="card__link">
            Learn More
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ========================================
   ABOUT PREVIEW
   ======================================== #}
<section class="section section--gray">
  <div class="container">
    <div class="about-preview">
      <div class="about-preview__content fade-in-left">
        <span class="section-header__label">{{ homepage.aboutPreview.label }}</span>
        <h2>{{ homepage.aboutPreview.title }}</h2>
        <p>{{ homepage.aboutPreview.paragraph1 }}</p>
        <p>{{ homepage.aboutPreview.paragraph2 | safe }}</p>
        <a href="about.html" class="btn btn--primary">{{ homepage.aboutPreview.buttonText }}</a>
      </div>
      <div class="about-preview__visual fade-in-right">
        <div class="big-number">{{ homepage.aboutPreview.visualNumber }}</div>
        <div class="big-label">{{ homepage.aboutPreview.visualLabel }}</div>
        <p class="about-preview__description">{{ homepage.aboutPreview.visualDescription }}</p>
      </div>
    </div>
  </div>
</section>

{# ========================================
   WHY CHOOSE US
   ======================================== #}
<section class="section section--dark">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-header__label">{{ homepage.whyChooseUs.label }}</span>
      <h2>{{ homepage.whyChooseUs.title }}</h2>
      <p>{{ homepage.whyChooseUs.description }}</p>
    </div>

    {% set valueIcons = [
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>'
    ] %}

    <div class="values-grid stagger-children">
      {% for value in homepage.whyChooseUs.values %}
        <div class="value-item fade-in">
          <div class="value-item__icon">
            {{ valueIcons[loop.index0] | safe }}
          </div>
          <h4>{{ value.title }}</h4>
          <p>{{ value.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ========================================
   INDUSTRIES
   ======================================== #}
<section class="section">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-header__label">{{ homepage.industriesSection.label }}</span>
      <h2>{{ homepage.industriesSection.title }}</h2>
      <p>{{ homepage.industriesSection.description }}</p>
    </div>

    {% set industryIcons = [
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v3"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>'
    ] %}

    <div class="industry-grid stagger-children">
      {% for item in homepage.industriesSection.items %}
        <a href="industries.html" class="industry-item fade-in">
          <div class="industry-item__icon">
            {{ industryIcons[loop.index0] | safe }}
          </div>
          <div class="industry-item__text">
            <h4>{{ item.title }}</h4>
            <p>{{ item.description }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ========================================
   DUAL CTA
   ======================================== #}
<section class="section section--gray">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-header__label">{{ homepage.dualCta.label }}</span>
      <h2>{{ homepage.dualCta.title }}</h2>
      <p>{{ homepage.dualCta.description }}</p>
    </div>

    <div class="dual-cta stagger-children">
      <div class="dual-cta__card dual-cta__card--sell fade-in">
        <div class="dual-cta__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
        </div>
        <h3>{{ homepage.dualCta.sellCard.title }}</h3>
        <p>{{ homepage.dualCta.sellCard.description }}</p>
        <a href="contact.html" class="btn btn--white">{{ homepage.dualCta.sellCard.buttonText }}</a>
      </div>
      <div class="dual-cta__card dual-cta__card--buy fade-in">
        <div class="dual-cta__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <h3>{{ homepage.dualCta.buyCard.title }}</h3>
        <p>{{ homepage.dualCta.buyCard.description }}</p>
        <a href="contact.html" class="btn btn--white">{{ homepage.dualCta.buyCard.buttonText }}</a>
      </div>
    </div>
  </div>
</section>

{# ========================================
   CTA BANNER
   ======================================== #}
<section class="section">
  <div class="container">
    <div class="cta-banner fade-in">
      <h2>{{ homepage.ctaBanner.title }}</h2>
      <p>{{ homepage.ctaBanner.description }}</p>
      <a href="contact.html" class="btn btn--secondary btn--large">{{ homepage.ctaBanner.buttonText }}</a>
    </div>
  </div>
</section>
